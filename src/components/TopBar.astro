---

---

<header
  class="fixed top-0 left-0 right-0 z-50 flex items-center justify-between gap-4 border-b border-border bg-surface px-4 py-3 dark:border-border-dark dark:bg-surface-dark"
  transition:persist
>
  <div class="flex items-center gap-3">
    <button
      id="sidebar-toggle"
      class="md:hidden rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-gray-800"
      aria-label="Toggle menu"
    >
      <svg class="h-5 w-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
    <a href="/" class="text-lg font-bold text-primary whitespace-nowrap">
      Smallwood Family Recipes
    </a>
  </div>

  <div class="flex-1 max-w-md mx-4">
    <input
      id="recipe-search"
      type="search"
      placeholder="Search recipes..."
      class="w-full rounded-lg border border-border bg-white px-3 py-1.5 text-sm outline-none focus:border-primary dark:border-border-dark dark:bg-gray-800 dark:text-text-dark"
    />
  </div>

  <button
    id="dark-mode-toggle"
    class="rounded-lg p-2 hover:bg-gray-100 dark:hover:bg-gray-800"
    aria-label="Toggle dark mode"
  >
    <svg id="sun-icon" class="h-5 w-5 hidden dark:block" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
    </svg>
    <svg id="moon-icon" class="h-5 w-5 block dark:hidden" fill="none" stroke="currentColor" viewBox="0 0 24 24">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
    </svg>
  </button>
</header>
